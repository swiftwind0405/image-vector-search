# Image Vector Search - example environment file
# Copy to .env and adjust as needed.

# Filesystem
IMAGE_SEARCH_IMAGES_ROOT=./example-images
IMAGE_SEARCH_INDEX_ROOT=./example-index

# Server
# IMAGE_SEARCH_HOST=0.0.0.0
# IMAGE_SEARCH_PORT=8000

# Search defaults
# IMAGE_SEARCH_DEFAULT_TOP_K=5
# IMAGE_SEARCH_MAX_TOP_K=50
# IMAGE_SEARCH_MIN_SCORE=0.0

# Embedding bootstrap defaults
# These values are optional at startup.
# You can also configure provider and API keys later in the admin settings page.
# If a provider/key is saved in the database, it takes precedence over the env fallback below.
# IMAGE_SEARCH_EMBEDDING_PROVIDER=jina
# IMAGE_SEARCH_EMBEDDING_MODEL=jina-clip-v2
# IMAGE_SEARCH_EMBEDDING_VERSION=v2
# IMAGE_SEARCH_JINA_API_KEY=
# IMAGE_SEARCH_GOOGLE_API_KEY=

# Gemini-specific options
# IMAGE_SEARCH_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# IMAGE_SEARCH_EMBEDDING_OUTPUT_DIMENSIONALITY=
# IMAGE_SEARCH_EMBEDDING_BATCH_SIZE=32

# Jina-specific rate limiting
# IMAGE_SEARCH_JINA_RPM=100
# IMAGE_SEARCH_JINA_MAX_CONCURRENCY=2

# Vector index storage
# IMAGE_SEARCH_VECTOR_INDEX_COLLECTION_NAME=image_embeddings
# IMAGE_SEARCH_VECTOR_INDEX_DB_FILENAME=milvus.db

# Optional admin authentication
# IMAGE_SEARCH_ADMIN_USERNAME=admin
# IMAGE_SEARCH_ADMIN_PASSWORD=change-me
# IMAGE_SEARCH_ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
