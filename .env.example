# Image Search MCP - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Jina API 密钥 (必需) - 获取地址: https://jina.ai/embeddings/
IMAGE_SEARCH_JINA_API_KEY=your_jina_api_key_here

# 图片根目录路径 (本地开发时修改为实际路径)
IMAGE_SEARCH_IMAGES_ROOT=/path/to/your/images

# 索引存储目录路径
IMAGE_SEARCH_INDEX_ROOT=/path/to/index/storage

# 服务端口 (可选，默认 8000)
# IMAGE_SEARCH_PORT=8000

# 服务主机 (可选，默认 0.0.0.0)
# IMAGE_SEARCH_HOST=0.0.0.0

# 默认返回结果数量 (可选，默认 5)
# IMAGE_SEARCH_DEFAULT_TOP_K=5

# 最大返回结果数量 (可选，默认 50)
# IMAGE_SEARCH_MAX_TOP_K=50

# 最小相似度分数 (可选，默认 0.0)
# IMAGE_SEARCH_MIN_SCORE=0.0

# 嵌入模型配置 (可选)
# IMAGE_SEARCH_EMBEDDING_PROVIDER=jina
# IMAGE_SEARCH_EMBEDDING_MODEL=jina-clip-v2
# IMAGE_SEARCH_EMBEDDING_VERSION=v2
# IMAGE_SEARCH_EMBEDDING_BATCH_SIZE=32

# Web 管理界面登录验证 (可选)
# 设置后访问管理界面需要登录，留空则不启用验证
# IMAGE_SEARCH_ADMIN_USERNAME=admin
# IMAGE_SEARCH_ADMIN_PASSWORD=your_password_here
# Session 签名密钥，留空则每次启动自动生成 (重启后会退出登录)
# IMAGE_SEARCH_ADMIN_SESSION_SECRET=your_session_secret_here
